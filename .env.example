PORT=3000

# ─── DEMO MODE ────────────────────────────────────────────────
# Leave SMTP fields empty to run in DEMO mode.
# Demo mode uses Ethereal (https://ethereal.email) — a fake SMTP
# service that captures emails without delivering them.
# Preview links are printed to the console for each sent email.
# ──────────────────────────────────────────────────────────────

# SMTP Configuration (optional — leave empty for demo mode)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Sender info (optional — defaults used in demo mode)
MAIL_FROM_NAME=Newsletter System
MAIL_FROM_ADDRESS=

# App
BASE_URL=http://localhost:3000
